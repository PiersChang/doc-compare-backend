# ── OpenAI ────────────────────────────────
OPENAI_API_KEY=sk-...你的OpenAI金鑰...

# ── JWT ───────────────────────────────────
JWT_SECRET=換成一個隨機長字串

# ── 免費額度 ──────────────────────────────
FREE_LIMIT=5

# ── 資料庫 ───────────────────────────────
DB_PATH=doc_compare.db

# ── PayPal ───────────────────────────────
# 到 https://developer.paypal.com 建立 App 取得以下資訊
PAYPAL_CLIENT_ID=你的PayPal_Client_ID
PAYPAL_SECRET=你的PayPal_Secret
# 到 PayPal 後台 Catalog > Products 建立產品，再建立訂閱方案取得 Plan ID
PAYPAL_PLAN_ID=P-XXXXXXXXXXXXXXXXXXXXXXXX
# 測試用 sandbox，上線後改 live
PAYPAL_MODE=sandbox

# ── 前端網址 ──────────────────────────────
FRONTEND_URL=http://localhost:3000
